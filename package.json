{
  "name": "af_backend",
  "version": "1.0.0",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --forceExit",
    "test:unit": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js tests/unit --forceExit --verbose",
    "test:unit:sessions": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js tests/unit/tutoringSession --forceExit --verbose",
    "test:integration": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js tests/integration --forceExit --verbose --runInBand",
    "test:integration:sessions": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js tests/integration/tutoringSession --forceExit --verbose --runInBand",
    "test:coverage": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --coverage --forceExit --runInBand",
    "test:perf:token": "node tests/performance/generate-perf-token.js",
    "test:perf": "artillery run tests/performance/study-material-load-test.yml",
    "test:perf:run": "artillery run tests/performance/study-material-load-test.yml --output tests/performance/report.json",
    "test:perf:report": "artillery report tests/performance/report.json --output tests/performance/report.html",
    "test:perf:sessions:token": "node tests/performance/generate-tutoring-perf-token.js",
    "test:perf:sessions": "artillery run tests/performance/tutoring-session-load-test.yml",
    "test:perf:sessions:run": "artillery run tests/performance/tutoring-session-load-test.yml --output tests/performance/sessions-report.json",
    "test:perf:sessions:report": "artillery report tests/performance/sessions-report.json --output tests/performance/sessions-report.html",
    "test:perf:helprequest:token": "node tests/performance/generate-helprequest-perf-token.js",
    "test:perf:helprequest": "artillery run tests/performance/help-request-load-test.yml",
    "test:perf:helprequest:run": "artillery run tests/performance/help-request-load-test.yml --output tests/performance/helprequest-report.json",
    "test:perf:helprequest:report": "artillery report tests/performance/helprequest-report.json --output tests/performance/helprequest-report.html",
    "test:unit:feedback": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js tests/unit/feedbackController.test.js --forceExit --verbose",
    "test:unit:progress": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js tests/unit/progressController.test.js --forceExit --verbose",
    "test:integration:feedback": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js tests/integration/feedback.test.js --forceExit --verbose --runInBand",
    "test:integration:progress": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js tests/integration/progress.test.js --forceExit --verbose --runInBand",
    "test:perf:feedback:token": "node tests/performance/generate-feedback-perf-token.js",
    "test:perf:feedback": "artillery run tests/performance/feedback-load-test.yml",
    "test:perf:feedback:run": "artillery run tests/performance/feedback-load-test.yml --output tests/performance/feedback-report.json",
    "test:perf:feedback:report": "artillery report tests/performance/feedback-report.json --output tests/performance/feedback-report.html",
    "test:perf:progress:token": "node tests/performance/generate-progress-perf-token.js",
    "test:perf:progress": "artillery run tests/performance/progress-load-test.yml",
    "test:perf:progress:run": "artillery run tests/performance/progress-load-test.yml --output tests/performance/progress-report.json",
    "test:perf:progress:report": "artillery report tests/performance/progress-report.json --output tests/performance/progress-report.html",
    "perf:load": "artillery run tests/performance/artillery-config.yml",
    "perf:load:report": "artillery run tests/performance/artillery-config.yml --output tests/performance/load-test-report.json && artillery report tests/performance/load-test-report.json",
    "perf:rampup": "artillery run tests/performance/artillery-rampup.yml",
    "perf:rampup:report": "artillery run tests/performance/artillery-rampup.yml --output tests/performance/rampup-report.json && artillery report tests/performance/rampup-report.json",
    "perf:spike": "artillery run tests/performance/artillery-spike.yml",
    "perf:spike:report": "artillery run tests/performance/artillery-spike.yml --output tests/performance/spike-report.json && artillery report tests/performance/spike-report.json",
    "perf:stress": "artillery run tests/performance/artillery-stress.yml",
    "perf:stress:report": "artillery run tests/performance/artillery-stress.yml --output tests/performance/stress-report.json && artillery report tests/performance/stress-report.json",
    "perf:all": "npm run perf:load:report && npm run perf:rampup:report && npm run perf:spike:report && npm run perf:stress:report",
    "component4:test": "npm run test:unit:feedback && npm run test:unit:progress && npm run test:integration:feedback && npm run test:integration:progress && npm run perf:load",
    "component4:perf": "npm run perf:load && npm run perf:rampup && npm run perf:spike && npm run perf:stress"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {},
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "testTimeout": 30000,
    "collectCoverageFrom": [
      "Controllers/**/*.js",
      "services/studyMaterialService.js",
      "services/tutoringSessionService.js",
      "utils/**/*.js",
      "Middleware/authMiddleware.js",
      "Middleware/studyMaterialValidation.js",
      "validations/tutoringSession.validation.js"
    ],
    "setupFilesAfterEnv": [
      "./tests/setup/jest.setup.js"
    ],
    "coverageDirectory": "tests/coverage",
    "coverageReporters": [
      "text",
      "lcov",
      "html"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^1.41.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-validator": "^7.3.1",
    "googleapis": "^168.0.0",
    "http-status-codes": "^2.3.0",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^7.1.0",
    "mongoose": "^9.2.1",
    "multer": "^2.0.2",
    "multer-storage-cloudinary": "^4.0.0",
    "nodemailer": "^8.0.1"
  },
  "devDependencies": {
    "@jest/globals": "^30.3.0",
    "artillery": "^2.0.21",
    "jest": "^30.3.0",
    "mongodb-memory-server": "^11.0.1",
    "nodemon": "^3.1.11",
    "supertest": "^7.2.2"
  }
}
